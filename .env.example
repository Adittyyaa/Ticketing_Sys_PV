# Supabase Configuration
# Get these from your Supabase project settings at https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (KEEP SECRET - Server-side only)
# Used for admin operations like creating users
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Application Settings
NODE_ENV=development

# Security Notes:
# 1. Never commit .env.local to version control
# 2. Use different keys for development and production
# 3. Service role key should NEVER be exposed to the client
# 4. Rotate keys if compromised
